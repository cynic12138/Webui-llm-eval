# ===== Webui-LLM-Eval 统一配置 =====

# 部署地址
HOST_IP=localhost
BACKEND_PORT=8000
FRONTEND_PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=llmeval
DB_PASS=llmeval123
DB_NAME=llmeval

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# 安全
SECRET_KEY=supersecretkey-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 额外来源（逗号分隔，自动包含 HOST_IP:FRONTEND_PORT）
CORS_EXTRA_ORIGINS=

# 代理（可选）
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,10.0.0.0/8

# Optional: Default LLM API Keys for evaluation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
